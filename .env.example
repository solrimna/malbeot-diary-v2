# ── App ──────────────────────────────────────────────
APP_ENV=development          # development | production
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ─────────────────────────────────────────
# 로컬 개발 (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./malbeot.db

# 프로덕션 (PostgreSQL on EC2)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/malbeot

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
USE_REDIS=False 

# ── OpenAI ───────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key

# ── STT(AZURE)─────────────────
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=koreacentral

# ── Web Push ─────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_SUB=
 
# ── BREVO ─────────────────
BREVO_API_KEY=
BREVO_SENDER_EMAIL: str = "noreply@haru-commit.com"
BREVO_SENDER_NAME: str = "하루.commit()"
FRONTEND_BASE_URL=https://haru-commit.com  
# 로컬:https://localhost:8000 운영: https://haru-commit.com